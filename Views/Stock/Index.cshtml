@{
    ViewData["Title"] = "Gestión de Stock";
}

<style>
    .contenedor-stock { max-width: 1200px; margin: 20px auto; padding: 20px; }
    .titulo-stock { color: #003366; font-weight: 700; margin-bottom: 20px; border-bottom: 3px solid #1409f3; display: inline-block; padding-bottom: 5px; }
    
    /* Buscador más compacto */
    .buscador-stock { border-radius: 10px; padding: 8px 15px; border: 2px solid #ddd; transition: all 0.3s ease; }
    .buscador-stock:focus { border-color: #1409f3; box-shadow: 0 0 8px rgba(20, 9, 243, 0.2); outline: none; }

    /* Estilos para achicar las filas */
    .tabla-stock { border-radius: 8px; overflow: hidden; background: white; }
    .tabla-stock thead { background-color: #003366; color: white; }
    
    /* Reducimos el padding de las celdas para que no sean altas */
    .table-sm-custom td, .table-sm-custom th {
        padding-top: 4px !important;
        padding-bottom: 4px !important;
        font-size: 0.85rem; /* Texto un poco más chico para ganar espacio */
        vertical-align: middle;
    }

    .nombre-producto { font-weight: 600; color: #333; line-height: 1.2; }
    
    /* Badges más pequeños para que no estiren la fila */
    .badge-stock { padding: 4px 10px; border-radius: 4px; font-weight: 600; min-width: 80px; font-size: 0.75rem; }

    .display-stock { font-size: 2.5rem; font-weight: 800; color: #003366; }
    .input-suma { font-size: 1.5rem; text-align: center; font-weight: bold; }
</style>

<div id="app" class="contenedor-stock">
    <h2 class="titulo-stock">
        <i class="bi bi-box-seam"></i> Control de Stock
    </h2>

    <div class="mb-3">
        <input type="text" 
               class="form-control buscador-stock" 
               placeholder="🔍 Buscar producto o proveedor..." 
               v-model="busqueda" 
               @@input="paginaActual = 1" />
    </div>

    <div class="table-responsive shadow-sm tabla-stock">
        @* Agregamos table-sm para reducir espacios *@
        <table class="table table-hover table-bordered table-sm table-sm-custom mb-0">
            <thead>
                <tr>
                    <th style="width: 40%;">Producto</th>
                    <th class="text-center">Proveedor</th> 
                    <th class="text-center" style="width: 150px;">Stock Actual</th>
                    <th class="text-center" style="width: 200px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr v-for="p in productosPaginados" :key="p.idProducto">
                    <td>
                        <div class="nombre-producto">{{ p.nombre }}</div>
                        <small class="text-muted">Cod: {{ p.codigo }}</small>
                    </td>
                    <td class="text-center text-proveedor">
                        {{ p.nombreProveedor || 'Sin Proveedor' }}
                    </td>
                    <td class="text-center">
                        <span :class="p.stockActual <= 5 ? 'badge bg-danger badge-stock' : 'badge bg-success badge-stock'">
                            {{ p.stockActual }} Unidades
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group">
                            <button class="btn btn-primary btn-sm py-0 px-2" v-on:click="abrirAjuste(p, 'suma')">
                                <i class="bi bi-plus"></i> Sumar
                            </button>
                            <button class="btn btn-outline-danger btn-sm py-0 px-2" v-on:click="abrirAjuste(p, 'resta')">
                                <i class="bi bi-dash"></i> Restar
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <nav v-if="totalPaginas > 1" class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            <li class="page-item" :class="{ disabled: paginaActual === 1 }">
                <a class="page-link" href="#" @@click.prevent="paginaActual--">Ant.</a>
            </li>
            <li v-for="n in totalPaginas" :key="n" class="page-item" :class="{ active: paginaActual === n }">
                <a class="page-link" href="#" @@click.prevent="paginaActual = n" 
                   v-if="n >= paginaActual - 3 && n <= paginaActual + 3">{{ n }}</a>
            </li>
            <li class="page-item" :class="{ disabled: paginaActual === totalPaginas }">
                <a class="page-link" href="#" @@click.prevent="paginaActual++">Sig.</a>
            </li>
        </ul>
        <div class="text-center text-muted">
            <small>Página {{ paginaActual }} de {{ totalPaginas }} (Mostrando de a 80 productos)</small>
        </div>
    </nav>

    <div class="modal fade" id="modalStock" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" v-if="seleccionado">
                <div :class="['modal-header text-white', modoAjuste === 'suma' ? 'bg-primary' : 'bg-danger']">
                    <h5 class="modal-title">{{ modoAjuste === 'suma' ? '📦 Carga de Stock' : '📉 Ajuste de Salida' }}</h5>
                    <button type="button" class="btn-close btn-close-white" @@click="cerrar"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <h5 class="mb-3">{{ seleccionado.nombre }}</h5>
                    <div class="display-stock mb-3">{{ seleccionado.stockActual }}</div>
                    <div class="form-group px-5">
                        <label class="mb-2 fw-bold">Cantidad:</label>
                        <input type="number" id="inputCantidad" class="form-control input-suma" v-model.number="cantidadIngresada" />
                    </div>
                </div>
                <div class="modal-footer justify-content-center">
                    <button class="btn btn-secondary px-4" @@click="cerrar">Cancelar</button>
                    <button :class="modoAjuste === 'suma' ? 'btn btn-success' : 'btn btn-danger'" 
                            class="px-4" @@click="confirmarGuardado">
                        Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@2"></script>
    <script>
        new Vue({
            el: '#app',
            data: {
                productos: [],
                busqueda: '',
                seleccionado: null,
                cantidadIngresada: 0,
                modoAjuste: 'suma',
                modalBS: null,
                paginaActual: 1,
                itemsPorPagina: 80 // CAMBIO: Ahora muestra 80 líneas
            },
            computed: {
                productosFiltrados() {
                    const f = this.busqueda.toLowerCase();
                    return this.productos.filter(p => 
                        (p.nombre && p.nombre.toLowerCase().includes(f)) || 
                        (p.codigo && p.codigo.toLowerCase().includes(f)) ||
                        (p.nombreProveedor && p.nombreProveedor.toLowerCase().includes(f))
                    );
                },
                productosPaginados() {
                    const inicio = (this.paginaActual - 1) * this.itemsPorPagina;
                    return this.productosFiltrados.slice(inicio, inicio + this.itemsPorPagina);
                },
                totalPaginas() { return Math.ceil(this.productosFiltrados.length / this.itemsPorPagina); }
            },
            methods: {
                cargar() {
                    fetch('/Stock/ObtenerProductos').then(r => r.json()).then(data => { this.productos = data; });
                },
                abrirAjuste(p, modo) {
                    this.modoAjuste = modo;
                    this.seleccionado = Object.assign({}, p);
                    this.cantidadIngresada = 0;
                    if (!this.modalBS) this.modalBS = new bootstrap.Modal(document.getElementById('modalStock'));
                    this.modalBS.show();
                },
                confirmarGuardado() { 
                    const cantidadFinal = this.modoAjuste === 'suma' ? this.cantidadIngresada : this.cantidadIngresada * -1;
                    fetch('/Stock/SumarStock', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ idProducto: this.seleccionado.idProducto, cantidad: cantidadFinal })
                    }).then(r => { 
                        if(r.ok) { 
                            this.cargar(); 
                            this.cerrar(); 
                        } 
                    });
                },
                cerrar() { if(this.modalBS) this.modalBS.hide(); this.seleccionado = null; }
            },
            mounted() { this.cargar(); }
        });
    </script>
}