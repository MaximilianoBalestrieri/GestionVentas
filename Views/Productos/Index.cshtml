@model List<GestionVentas.Models.Productos>
@{
    ViewBag.Title = "Productos";
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int paginaActual = ViewBag.PaginaActual ?? 1;
    string busquedaActual = ViewBag.Busqueda ?? "";
}

<style>
    .table-sm-custom td, .table-sm-custom th {
        padding-top: 2px !important;
        padding-bottom: 2px !important;
        vertical-align: middle;
    }
    .img-prev {
        width: 30px;
        height: 30px;
        object-fit: cover;
        border-radius: 4px;
    }
</style>

<div class="container mt-4">
    @* Formulario cambiado a GET para que la búsqueda persista al recargar/paginar *@
    <form class="mb-3 d-flex align-items-center gap-2" method="get" action="@Url.Action("Index")">
        <div class="mb-3 d-flex align-items-center gap-2">
            <div class="input-group input-group-sm" style="width: 250px;">
                <span class="input-group-text bg-white border-end-0">🔍</span>
                <input type="text" id="inputBusqueda" name="busqueda" value="@busquedaActual" placeholder="Producto o código..." class="form-control border-start-0" autocomplete="off" />
            </div>

            <div class="input-group input-group-sm" style="width: 200px;">
                <span class="input-group-text bg-white border-end-0">🚚</span>
                <input type="text" id="inputProveedor" placeholder="Filtrar proveedor..." class="form-control border-start-0" />
            </div>
            @* Botón oculto para que el "Enter" funcione naturalmente *@
            <button type="submit" style="display:none;"></button>
        </div>
    </form>

   <div class="d-flex align-items-baseline gap-3 mb-4">
    <h1>🛒 Productos</h1>
    <h3 class="text-muted fw-light" style="font-size: 1.2rem;">
        (Se encontraron <span id="contadorProductos">@ViewBag.TotalRegistros</span> productos)
    </h3>
</div>
    <a href="@Url.Action("Create", "Productos")" class="btn btn-primary mb-3">
        ➕ Agregar Producto
    </a>

    <table class="table table-striped table-bordered small table-sm-custom">
        <thead class="table-dark">
            <tr>
                <th class="text-center">Código</th>
                <th style="width: 250px;">Nombre</th>
                <th class="text-end">Precio Costo</th>
                <th class="text-center">Recargo (%)</th>
                <th class="text-end">Precio Venta</th>
                <th class="text-center">Stock</th>
                <th id="ordenarProveedor" style="cursor:pointer;">Proveedor 🔽</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prod in Model)
            {
                var rutaImagen = prod.Imagen?.Replace("\\", "/") ?? "";
                if (!string.IsNullOrEmpty(rutaImagen) && !rutaImagen.StartsWith("/"))
                {
                    rutaImagen = "/" + rutaImagen;
                }

                var stockClass = prod.StockActual <= 3 ? "text-danger fw-bold" : "";

                <tr>
                    <td class="text-center">@prod.Codigo</td>
                    <td>@prod.Nombre</td>
                    <td class="text-end">$@prod.PrecioCosto.ToString("0.00")</td>
                    <td class="text-center">@prod.RecargoPorcentaje %</td>
                    <td class="text-end"><strong>$@prod.PrecioVenta.ToString("0.00")</strong></td>
                    <td class="text-center @stockClass">@prod.StockActual</td>
                    <td>@prod.NombreProveedor</td>
                    <td class="text-center">
                        <a href="@Url.Action("Edit", "Productos", new { id = prod.IdProducto })" class="btn btn-sm btn-warning">✏️</a>
                        <a href="@Url.Action("Delete", "Productos", new { id = prod.IdProducto })" class="btn btn-sm btn-danger">🗑️</a>
                        <button type="button"
                                class="btn btn-sm btn-info"
                                data-bs-toggle="modal"
                                data-bs-target="#modalImagen"
                                data-img="@rutaImagen"
                                data-nombre="@prod.Nombre"
                                data-descripcion="@prod.Descripcion">
                            🖼️
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

  <div id="contenedorPaginacion">
    <nav id="navPaginacion">
        <ul class="pagination justify-content-center mt-4">
            @if (paginaActual > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { pagina = paginaActual - 1, busqueda = busquedaActual })">Anterior</a>
                </li>
            }

            @for (int i = 1; i <= totalPaginas; i++)
            {
                if (i == 1 || i == totalPaginas || (i >= paginaActual - 2 && i <= paginaActual + 2))
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { pagina = i, busqueda = busquedaActual })">@i</a>
                    </li>
                }
                else if (i == paginaActual - 3 || i == paginaActual + 3)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
            }

            @if (paginaActual < totalPaginas)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { pagina = paginaActual + 1, busqueda = busquedaActual })">Siguiente</a>
                </li>
            }
        </ul>
    </nav>
  </div>  
</div>

@* MODAL IMAGEN (Igual que el tuyo) *@
<div class="modal fade" id="modalImagen" tabindex="-1" aria-labelledby="modalImagenLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content text-center">
      <div class="modal-header">
        <h5 class="modal-title" id="modalImagenLabel">Detalles</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <h6 id="nombreProducto" class="mb-2"></h6>
        <img id="imagenProducto" src="" alt="Imagen" width="180" height="180" style="object-fit: cover; border: 1px solid #ccc; border-radius: 8px;"
             onerror="this.src='/imagenes/no-disponible.png'; document.getElementById('mensajeImagen').style.display = 'block';" />
        <p id="descripcionProducto" class="text-muted mt-2" style="font-size: 0.9rem;"></p>
        <p id="mensajeImagen" style="display:none; color: red; margin-top: 10px;">⚠️ Sin imagen disponible.</p>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
    // Lógica del Modal
    const modalImagen = document.getElementById('modalImagen');
    modalImagen.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        document.getElementById('imagenProducto').src = button.getAttribute('data-img');
        document.getElementById('nombreProducto').textContent = button.getAttribute('data-nombre');
        document.getElementById('descripcionProducto').textContent = button.getAttribute('data-descripcion');
        document.getElementById('mensajeImagen').style.display = 'none';
    });

    const inputBusqueda = document.getElementById('inputBusqueda');
    const inputProveedor = document.getElementById('inputProveedor');

function realizarBusqueda(pagina = 1) {
    const term = inputBusqueda.value.trim();
    const prov = inputProveedor.value.trim();

    fetch(`/Productos/Buscar?term=${encodeURIComponent(term)}&proveedor=${encodeURIComponent(prov)}&pagina=${pagina}`)
        .then(response => {
            // Leemos los headers que configuramos en el controlador
            const totalReal = response.headers.get("X-Total-Count");
            const totalPaginas = response.headers.get("X-Total-Paginas");
            const paginaActual = parseInt(response.headers.get("X-Pagina-Actual") || pagina);

            // 1. Actualizar contador de productos
            if (totalReal) document.getElementById('contadorProductos').textContent = totalReal;
            
            // 2. Reconstruir los botones de paginación
            if (totalPaginas) actualizarPaginacion(paginaActual, parseInt(totalPaginas));

            return response.json();
        })
        .then(data => {
            const tbody = document.querySelector("table tbody");
            tbody.innerHTML = "";
            
            data.forEach(prod => {
                let stockClass = prod.stockActual <= 3 ? 'text-danger fw-bold' : '';
                let fila = `<tr>
                    <td class="text-center">${prod.codigo || ''}</td>
                    <td>${prod.nombre || ''}</td>
                    <td class="text-end">$${prod.precioCosto.toFixed(2)}</td>
                    <td class="text-center">${prod.recargoPorcentaje} %</td>
                    <td class="text-end"><strong>$${prod.precioVenta.toFixed(2)}</strong></td>
                    <td class="text-center ${stockClass}">${prod.stockActual}</td>
                    <td>${prod.nombreProveedor || '.'}</td>
                    <td class="text-center">
                        <a href="/Productos/Edit/${prod.idProducto}" class="btn btn-sm btn-warning">✏️</a>
                        <a href="/Productos/Delete/${prod.idProducto}" class="btn btn-sm btn-danger">🗑️</a>
                        <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#modalImagen" 
                                data-img="${prod.imagen || ''}" data-nombre="${prod.nombre}" data-descripcion="${prod.descripcion}">🖼️</button>
                    </td>
                </tr>`;
                tbody.innerHTML += fila;
            });
        });
}

    inputBusqueda.addEventListener('input', realizarBusqueda);
    inputProveedor.addEventListener('input', realizarBusqueda);

    // Ordenar por Proveedor (Mantiene tu lógica)
    let ordenAsc = true;
    document.getElementById('ordenarProveedor').addEventListener('click', function () {
        const tbody = document.querySelector("table tbody");
        const filas = Array.from(tbody.querySelectorAll("tr"));
        filas.sort((a, b) => {
            const provA = a.children[6].textContent.trim().toLowerCase();
            const provB = b.children[6].textContent.trim().toLowerCase();
            return ordenAsc ? provA.localeCompare(provB) : provB.localeCompare(provA);
        });
        tbody.innerHTML = "";
        filas.forEach(f => tbody.appendChild(f));
        ordenAsc = !ordenAsc;
        this.textContent = `Proveedor ${ordenAsc ? "🔽" : "🔼"}`;
    });


function actualizarPaginacion(actual, total) {
    const contenedor = document.getElementById('contenedorPaginacion');
    if (!contenedor) return;
    
    // Si no hay resultados o solo hay 1 página, limpiamos la paginación
    if (total <= 1) {
        contenedor.innerHTML = "";
        return;
    }

    let html = `<nav id="navPaginacion"><ul class="pagination justify-content-center mt-4">`;

    // Botón Anterior
    if (actual > 1) {
        html += `<li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="realizarBusqueda(${actual - 1})">Anterior</a>
                 </li>`;
    }

    // Bucle de páginas (Igual a tu lógica de C#)
    for (let i = 1; i <= total; i++) {
        if (i === 1 || i === total || (i >= actual - 2 && i <= actual + 2)) {
            html += `<li class="page-item ${i === actual ? 'active' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="realizarBusqueda(${i})">${i}</a>
                     </li>`;
        } else if (i === actual - 3 || i === actual + 3) {
            html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
        }
    }

    // Botón Siguiente
    if (actual < total) {
        html += `<li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="realizarBusqueda(${actual + 1})">Siguiente</a>
                 </li>`;
    }

    html += `</ul></nav>`;
    contenedor.innerHTML = html;
}


</script>
}